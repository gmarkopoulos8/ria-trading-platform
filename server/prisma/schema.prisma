generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  displayName  String
  passwordHash String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings          UserSettings?
  watchlists        Watchlist[]
  portfolios        Portfolio[]
  alerts            Alert[]
  theses            Thesis[]
  agentOutputs      AgentOutput[]
  auditLogs         AuditLog[]
  performanceMetrics PerformanceMetric[]
  stockSearchHistory StockSearchHistory[]

  @@index([email])
  @@map("users")
}

model UserSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  theme                String   @default("dark")
  defaultPortfolioId   String?
  riskTolerance        String   @default("medium")
  maxPositionPct       Float    @default(10.0)
  dailyLossLimit       Float    @default(5000.0)
  notificationsEnabled Boolean  @default(true)
  emailAlerts          Boolean  @default(false)
  stocksApiKey         String?
  cryptoApiKey         String?
  preferences          Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ─── Watchlists ───────────────────────────────────────────────────

model Watchlist {
  id          String  @id @default(cuid())
  userId      String
  name        String
  description String?
  isDefault   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WatchlistItem[]

  @@index([userId])
  @@map("watchlists")
}

model WatchlistItem {
  id          String  @id @default(cuid())
  watchlistId String
  symbol      String
  notes       String?
  alertPrice  Float?
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, symbol])
  @@index([symbol])
  @@map("watchlist_items")
}

// ─── Market Data ─────────────────────────────────────────────────

model Symbol {
  id          String     @id @default(cuid())
  ticker      String     @unique
  name        String
  assetClass  AssetClass
  exchange    String?
  sector      String?
  industry    String?
  description String?
  logoUrl     String?
  isActive    Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  snapshots        SymbolSnapshot[]
  technicalSignals TechnicalSignal[]
  patterns         Pattern[]
  newsItems        NewsItem[]
  catalystScores   CatalystScore[]
  riskScores       RiskScore[]
  theses           Thesis[]
  agentOutputs     AgentOutput[]
  dailyScanResults DailyScanResult[]     @relation("DailyScanResultSymbol")
  rankedSnapshots  RankedOpportunitySnapshot[] @relation("RankedOpportunitySnapshotSymbol")

  @@index([ticker])
  @@index([assetClass])
  @@map("symbols")
}

model SymbolSnapshot {
  id         String   @id @default(cuid())
  symbolId   String
  ticker     String
  open       Float?
  high       Float?
  low        Float?
  close      Float?
  volume     Float?
  marketCap  Float?
  changeAmt  Float?
  changePct  Float?
  vwap       Float?
  snapshotAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  symbol Symbol @relation(fields: [symbolId], references: [id], onDelete: Cascade)

  @@index([symbolId, snapshotAt])
  @@index([ticker])
  @@map("symbol_snapshots")
}

model TechnicalSignal {
  id         String   @id @default(cuid())
  symbolId   String
  ticker     String
  signalType String
  value      Float?
  signal     String?
  timeframe  String   @default("1D")
  metadata   Json?
  capturedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  symbol Symbol @relation(fields: [symbolId], references: [id], onDelete: Cascade)

  @@index([symbolId, signalType])
  @@index([ticker])
  @@map("technical_signals")
}

model Pattern {
  id          String    @id @default(cuid())
  symbolId    String
  ticker      String
  patternType String
  direction   String
  confidence  Float     @default(0)
  startDate   DateTime?
  endDate     DateTime?
  priceTarget Float?
  metadata    Json?
  detectedAt  DateTime  @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  symbol Symbol @relation(fields: [symbolId], references: [id], onDelete: Cascade)

  @@index([symbolId])
  @@index([ticker, patternType])
  @@map("patterns")
}

// ─── News & Catalysts ─────────────────────────────────────────────

model NewsItem {
  id          String    @id @default(cuid())
  symbolId    String?
  ticker      String?
  headline    String
  summary     String?
  url         String?
  source      String?
  sentiment   String?
  impact      String?
  publishedAt DateTime?
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  symbol Symbol? @relation(fields: [symbolId], references: [id], onDelete: SetNull)

  @@index([symbolId])
  @@index([ticker])
  @@index([publishedAt])
  @@map("news_items")
}

model CatalystScore {
  id        String    @id @default(cuid())
  symbolId  String
  ticker    String
  scoreType String
  score     Float     @default(0)
  direction String?
  magnitude String?
  expiresAt DateTime?
  metadata  Json?
  scoredAt  DateTime  @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  symbol Symbol @relation(fields: [symbolId], references: [id], onDelete: Cascade)

  @@index([symbolId])
  @@index([ticker, scoreType])
  @@map("catalyst_scores")
}

model RiskScore {
  id                String   @id @default(cuid())
  symbolId          String
  ticker            String
  overallRisk       Float    @default(0)
  volatilityRisk    Float    @default(0)
  liquidityRisk     Float    @default(0)
  concentrationRisk Float    @default(0)
  marketRisk        Float    @default(0)
  metadata          Json?
  scoredAt          DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  symbol Symbol @relation(fields: [symbolId], references: [id], onDelete: Cascade)

  @@index([symbolId])
  @@index([ticker])
  @@map("risk_scores")
}

// ─── Research ─────────────────────────────────────────────────────

model Thesis {
  id          String      @id @default(cuid())
  userId      String
  symbolId    String?
  ticker      String?
  title       String
  body        String
  conviction  Int         @default(5)
  timeHorizon String?
  tags        String[]
  status      ThesisStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol Symbol? @relation(fields: [symbolId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([ticker])
  @@map("theses")
}

// ─── Paper Trading ────────────────────────────────────────────────

model Portfolio {
  id          String @id @default(cuid())
  userId      String
  name        String
  cashBalance Float  @default(100000)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions PaperPosition[]
  closed    ClosedPosition[]
  metrics   PerformanceMetric[]

  @@index([userId])
  @@map("portfolios")
}

model PaperPosition {
  id                   String         @id @default(cuid())
  portfolioId          String
  userId               String
  symbol               String
  name                 String
  assetClass           String         @default("stock")
  side                 PositionSide
  quantity             Float
  entryPrice           Float
  currentPrice         Float?
  targetPrice          Float?
  stopLoss             Float?
  thesis               String
  thesisHealth         Float?
  tags                 String[]
  status               PositionStatus @default(OPEN)
  openedAt             DateTime       @default(now())
  recommendedAction    String?
  lastMonitoredAt      DateTime?
  lastThesisAnalysis   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  portfolio        Portfolio          @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  monitoringAlerts MonitoringAlert[]
  snapshots        PositionSnapshot[]

  @@index([portfolioId])
  @@index([userId])
  @@index([symbol])
  @@map("paper_positions")
}

model ClosedPosition {
  id                String       @id @default(cuid())
  portfolioId       String
  userId            String
  symbol            String
  name              String
  assetClass        String       @default("stock")
  side              PositionSide
  quantity          Float
  entryPrice        Float
  exitPrice         Float
  targetPrice       Float?
  stopLoss          Float?
  pnl               Float
  pnlPercent        Float
  thesis            String
  thesisOutcome     String?
  tags              String[]
  notes             String?
  closeReason       String?
  openedAt          DateTime
  closedAt          DateTime     @default(now())
  holdingPeriodDays Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
  @@index([userId])
  @@index([symbol])
  @@map("closed_positions")
}

// ─── Position Monitoring ─────────────────────────────────────────

model MonitoringAlert {
  id          String               @id @default(cuid())
  userId      String
  positionId  String?
  symbol      String
  severity    MonitorAlertSeverity
  alertType   MonitorAlertType
  title       String
  message     String
  isRead      Boolean              @default(false)
  metadata    Json?
  triggeredAt DateTime             @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  position PaperPosition? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@index([userId, triggeredAt])
  @@index([positionId])
  @@index([symbol])
  @@map("monitoring_alerts")
}

model PositionSnapshot {
  id                String   @id @default(cuid())
  positionId        String
  symbol            String
  currentPrice      Float
  thesisHealth      Float
  recommendedAction String?
  technicalScore    Float?
  catalystScore     Float?
  riskScore         Float?
  targetProximityPct Float?
  stopProximityPct  Float?
  holdWindowPct     Float?
  unrealizedPnl     Float
  unrealizedPnlPct  Float
  metadata          Json?
  snapshotAt        DateTime @default(now())

  createdAt DateTime @default(now())

  position PaperPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([positionId, snapshotAt])
  @@index([symbol])
  @@map("position_snapshots")
}

// ─── Alerts ───────────────────────────────────────────────────────

model Alert {
  id          String         @id @default(cuid())
  userId      String
  symbol      String
  type        AlertType
  condition   AlertCondition
  threshold   Float
  message     String?
  status      AlertStatus    @default(ACTIVE)
  triggeredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([symbol, status])
  @@map("alerts")
}

// ─── Analytics ───────────────────────────────────────────────────

model PerformanceMetric {
  id             String    @id @default(cuid())
  userId         String
  portfolioId    String?
  period         String
  totalTrades    Int       @default(0)
  winningTrades  Int       @default(0)
  losingTrades   Int       @default(0)
  winRate        Float     @default(0)
  avgWin         Float     @default(0)
  avgLoss        Float     @default(0)
  profitFactor   Float     @default(0)
  sharpeRatio    Float?
  maxDrawdown    Float     @default(0)
  totalReturn    Float     @default(0)
  totalReturnPct Float     @default(0)
  metadata       Json?
  periodStart    DateTime?
  periodEnd      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio Portfolio? @relation(fields: [portfolioId], references: [id], onDelete: SetNull)

  @@index([userId, period])
  @@index([portfolioId])
  @@map("performance_metrics")
}

// ─── AI Agent ─────────────────────────────────────────────────────

model AgentOutput {
  id         String  @id @default(cuid())
  userId     String?
  symbolId   String?
  ticker     String?
  agentType  String
  input      Json?
  output     Json?
  score      Float?
  confidence Float?
  metadata   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  symbol Symbol? @relation(fields: [symbolId], references: [id], onDelete: SetNull)

  @@index([userId, agentType])
  @@index([symbolId, agentType])
  @@index([ticker])
  @@map("agent_outputs")
}

model AuditLog {
  id        String  @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ─── Stock Health Analyzer ────────────────────────────────────────

model StockSearchHistory {
  id              String   @id @default(cuid())
  userId          String
  ticker          String
  lastHealthScore Float?
  lastActionLabel String?
  searchCount     Int      @default(1)
  lastSearchedAt  DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
  @@index([userId, lastSearchedAt])
  @@map("stock_search_history")
}

// ─── Daily Scan Engine ───────────────────────────────────────────

model DailyScanRun {
  id                  String   @id @default(cuid())
  runType             String   @default("SCHEDULED") // SCHEDULED | PREMARKET | MANUAL
  status              String   @default("PENDING")   // PENDING | RUNNING | COMPLETED | FAILED | PARTIAL
  startedAt           DateTime?
  completedAt         DateTime?
  scheduledFor        DateTime?
  marketSession       String   @default("MARKET_OPEN") // PREMARKET | MARKET_OPEN | MIDDAY
  assetScope          String   @default("ALL")          // ALL | STOCKS_ONLY | CRYPTO_ONLY
  riskMode            String   @default("ALL")          // ALL | CONSERVATIVE | AGGRESSIVE
  totalUniverseCount  Int      @default(0)
  totalRankedCount    Int      @default(0)
  topSymbol           String?
  summary             String?
  errorMessage        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  results DailyScanResult[]
  snapshots RankedOpportunitySnapshot[]
  report    DailyMarketReport?

  @@index([status])
  @@index([scheduledFor])
  @@index([runType, status])
  @@map("daily_scan_runs")
}

model DailyScanResult {
  id                   String @id @default(cuid())
  scanRunId            String
  symbolId             String?
  symbol               String
  assetClass           String @default("STOCK")
  rank                 Int
  bias                 String @default("NEUTRAL")
  convictionScore      Float  @default(0)
  confidenceScore      Float  @default(0)
  technicalScore       Float  @default(0)
  catalystScore        Float  @default(0)
  riskScore            Float  @default(0)
  volatilityScore      Float  @default(0)
  liquidityScore       Float  @default(0)
  setupType            String?
  trendState           String?
  supportZoneJson      Json?
  resistanceZoneJson   Json?
  entryZoneJson        Json?
  invalidationZoneJson Json?
  takeProfit1Json      Json?
  takeProfit2Json      Json?
  suggestedHoldWindow  String?
  thesisHealthScore    Float  @default(0)
  monitoringFrequency  String @default("DAILY")
  supportingReasonsJson Json?
  mainRiskToThesis     String?
  catalystSummary      String?
  patternSummary       String?
  recommendedAction    String @default("watch-for-confirmation")
  thesisId             String?
  rawAgentOutputJson   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scanRun DailyScanRun @relation(fields: [scanRunId], references: [id], onDelete: Cascade)
  symbol_ Symbol?      @relation("DailyScanResultSymbol", fields: [symbolId], references: [id], onDelete: SetNull)

  @@index([scanRunId, rank])
  @@index([symbol])
  @@index([scanRunId, symbol])
  @@map("daily_scan_results")
}

model RankedOpportunitySnapshot {
  id                   String   @id @default(cuid())
  symbolId             String?
  scanRunId            String
  symbol               String
  rank                 Int
  scoreComposite       Float    @default(0)
  scoreTechnical       Float    @default(0)
  scoreCatalyst        Float    @default(0)
  scoreRiskAdjusted    Float    @default(0)
  scoreVolatilityFit   Float    @default(0)
  scoreLiquidity       Float    @default(0)
  scoreTimeHorizonFit  Float    @default(0)
  scoreMonitorability  Float    @default(0)
  scoreRewardRisk      Float    @default(0)
  scoreInvalidationClarity Float @default(0)
  snapshotDate         DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scanRun  DailyScanRun @relation(fields: [scanRunId], references: [id], onDelete: Cascade)
  symbol_  Symbol?      @relation("RankedOpportunitySnapshotSymbol", fields: [symbolId], references: [id], onDelete: SetNull)

  @@index([scanRunId])
  @@index([symbol, snapshotDate])
  @@index([snapshotDate])
  @@map("ranked_opportunity_snapshots")
}

model DailyMarketReport {
  id                          String   @id @default(cuid())
  scanRunId                   String   @unique
  reportDate                  DateTime
  marketRegimeSummary         String?
  strongestSectorsJson        Json?
  weakestSectorsJson          Json?
  strongestMomentumJson       Json?
  highestRiskNamesJson        Json?
  topConservativeCandidatesJson Json?
  topAggressiveCandidatesJson Json?
  topCatalystsJson            Json?
  topConvictionSetupsJson     Json?
  topRiskRewardSetupsJson     Json?
  reportSummary               String?
  countsByAssetClass          Json?
  countsByBias                Json?
  countsByAction              Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scanRun DailyScanRun @relation(fields: [scanRunId], references: [id], onDelete: Cascade)

  @@index([reportDate])
  @@map("daily_market_reports")
}

// ─── Enums ───────────────────────────────────────────────────────

enum AssetClass {
  STOCK
  CRYPTO
  ETF
  FOREX
  FUTURES
}

enum ThesisStatus {
  ACTIVE
  CLOSED
  INVALIDATED
}

enum PositionSide {
  LONG
  SHORT
}

enum PositionStatus {
  OPEN
  CLOSED
  PENDING
}

enum AlertType {
  PRICE
  VOLUME
  NEWS
  TECHNICAL
  CATALYST
}

enum AlertCondition {
  ABOVE
  BELOW
  CROSSES
  PERCENT_CHANGE
}

enum AlertStatus {
  ACTIVE
  TRIGGERED
  DISMISSED
}

enum MonitorAlertSeverity {
  INFO
  CAUTION
  WARNING
  CRITICAL
}

enum MonitorAlertType {
  ENTRY_ZONE_REACHED
  BREAKOUT_CONFIRMED
  SUPPORT_LOST
  MOMENTUM_ACCELERATING
  MOMENTUM_FADING
  MAJOR_NEWS_DETECTED
  EVENT_RISK_ELEVATED
  INVALIDATION_THREATENED
  TARGET_APPROACHED
  HOLD_WINDOW_NEARLY_EXHAUSTED
  SETUP_INVALIDATED
  THESIS_HEALTH_IMPROVED
  THESIS_HEALTH_DETERIORATED
}

// ─── Polymarket ───────────────────────────────────────────────────

model PolymarketEvent {
  id           String   @id
  slug         String?
  title        String
  description  String?
  category     String?
  startDate    DateTime?
  endDate      DateTime?
  closed       Boolean  @default(false)
  imageUrl     String?
  rawPayload   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  markets PolymarketMarket[]

  @@map("polymarket_events")
}

model PolymarketMarket {
  id               String   @id
  eventId          String?
  slug             String?
  question         String
  description      String?
  category         String?
  conditionId      String?
  outcomes         Json
  outcomePrices    Json
  volume           Float    @default(0)
  liquidity        Float    @default(0)
  active           Boolean  @default(true)
  closed           Boolean  @default(false)
  archived         Boolean  @default(false)
  endDate          DateTime?
  imageUrl         String?
  rawPayload       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event     PolymarketEvent?    @relation(fields: [eventId], references: [id])
  snapshots PolymarketMarketSnapshot[]
  theses    PolymarketThesis[]
  positions PolymarketPaperPosition[]

  @@index([eventId])
  @@index([active, closed])
  @@map("polymarket_markets")
}

model PolymarketMarketSnapshot {
  id           String   @id @default(cuid())
  marketId     String
  yesPrice     Float?
  noPrice      Float?
  midpoint     Float?
  spread       Float?
  volume24h    Float?
  liquidity    Float?
  momentum     Float?
  rawOrderbook Json?

  snapshotAt DateTime @default(now())

  market PolymarketMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId, snapshotAt])
  @@map("polymarket_market_snapshots")
}

model PolymarketThesis {
  id                String   @id @default(cuid())
  marketId          String
  userId            String?
  healthScore       Float
  bias              String
  confidenceScore   Float
  liquidityScore    Float
  momentumScore     Float
  riskScore         Float
  actionLabel       String
  thesisSummary     String
  supportingReasons Json
  mainRisk          String
  suggestedHold     String
  priceSnapshot     Json?
  analyzedAt        DateTime @default(now())

  market PolymarketMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId])
  @@index([userId])
  @@map("polymarket_theses")
}

model PolymarketPaperPosition {
  id               String    @id @default(cuid())
  userId           String
  marketId         String
  eventId          String?
  question         String
  selectedSide     String
  entryProbability Float
  quantity         Float
  capitalAllocated Float
  currentMark      Float?
  unrealizedPnl    Float?
  thesisId         String?
  thesisHealth     Float?
  notes            String?
  status           String    @default("open")

  openedAt  DateTime  @default(now())
  closedAt  DateTime?
  updatedAt DateTime  @updatedAt

  market    PolymarketMarket @relation(fields: [marketId], references: [id])
  closed    PolymarketClosedPosition?
  alerts    PolymarketAlert[]

  @@index([userId, status])
  @@map("polymarket_paper_positions")
}

model PolymarketClosedPosition {
  id               String   @id @default(cuid())
  positionId       String   @unique
  userId           String
  marketId         String
  question         String
  selectedSide     String
  entryProbability Float
  exitProbability  Float
  quantity         Float
  capitalAllocated Float
  realizedPnl      Float
  pnlPercent       Float
  resolution       String?
  thesisId         String?
  notes            String?

  openedAt  DateTime
  closedAt  DateTime @default(now())

  position PolymarketPaperPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([marketId])
  @@map("polymarket_closed_positions")
}

model PolymarketAlert {
  id           String   @id @default(cuid())
  userId       String
  positionId   String?
  marketId     String
  alertType    String
  severity     String   @default("info")
  title        String
  message      String
  isRead       Boolean  @default(false)
  isDismissed  Boolean  @default(false)
  metadata     Json?

  createdAt DateTime @default(now())

  position PolymarketPaperPosition? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@index([marketId])
  @@map("polymarket_alerts")
}

model PolymarketSearchHistory {
  id              String   @id @default(cuid())
  userId          String
  marketId        String
  question        String
  lastHealthScore Float?
  lastActionLabel String?
  searchCount     Int      @default(1)
  lastSearchedAt  DateTime @default(now())

  @@unique([userId, marketId])
  @@index([userId])
  @@map("polymarket_search_history")
}

enum PolymarketSide {
  YES
  NO
}

// ─── Hyperliquid ──────────────────────────────────────────────────

model HyperliquidOrderLog {
  id            String   @id @default(cuid())
  userId        String
  asset         String
  side          String
  orderType     String
  price         String?
  size          String
  leverage      Int      @default(1)
  reduceOnly    Boolean  @default(false)
  isDryRun      Boolean  @default(true)
  status        String   @default("submitted")
  exchangeOid   String?
  errorMessage  String?
  rawResponse   Json?

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([asset])
  @@map("hl_order_logs")
}

model HyperliquidKillEvent {
  id         String   @id @default(cuid())
  userId     String?
  reason     String
  trigger    String
  snapshot   Json?
  createdAt  DateTime @default(now())

  @@map("hl_kill_events")
}

// ─── Schwab / ThinkorSwim ─────────────────────────────────────────

model TosOrderLog {
  id            String   @id @default(cuid())
  userId        String
  symbol        String
  instruction   String
  orderType     String
  price         String?
  stopPrice     String?
  quantity      String
  duration      String   @default("DAY")
  isDryRun      Boolean  @default(true)
  status        String   @default("pending")
  exchangeOid   String?
  errorMessage  String?
  rawResponse   Json?

  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([symbol])
  @@map("tos_order_logs")
}

model TosKillEvent {
  id         String   @id @default(cuid())
  userId     String?
  reason     String
  trigger    String
  snapshot   Json?
  createdAt  DateTime @default(now())

  @@map("tos_kill_events")
}
