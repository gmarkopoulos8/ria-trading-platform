generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  displayName  String
  passwordHash String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings          UserSettings?
  watchlists        Watchlist[]
  portfolios        Portfolio[]
  alerts            Alert[]
  theses            Thesis[]
  agentOutputs      AgentOutput[]
  auditLogs         AuditLog[]
  performanceMetrics PerformanceMetric[]

  @@index([email])
  @@map("users")
}

model UserSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  theme                String   @default("dark")
  defaultPortfolioId   String?
  riskTolerance        String   @default("medium")
  maxPositionPct       Float    @default(10.0)
  dailyLossLimit       Float    @default(5000.0)
  notificationsEnabled Boolean  @default(true)
  emailAlerts          Boolean  @default(false)
  stocksApiKey         String?
  cryptoApiKey         String?
  preferences          Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ─── Watchlists ───────────────────────────────────────────────────

model Watchlist {
  id          String  @id @default(cuid())
  userId      String
  name        String
  description String?
  isDefault   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WatchlistItem[]

  @@index([userId])
  @@map("watchlists")
}

model WatchlistItem {
  id          String  @id @default(cuid())
  watchlistId String
  symbol      String
  notes       String?
  alertPrice  Float?
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, symbol])
  @@index([symbol])
  @@map("watchlist_items")
}

// ─── Market Data ─────────────────────────────────────────────────

model Symbol {
  id          String     @id @default(cuid())
  ticker      String     @unique
  name        String
  assetClass  AssetClass
  exchange    String?
  sector      String?
  industry    String?
  description String?
  logoUrl     String?
  isActive    Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  snapshots        SymbolSnapshot[]
  technicalSignals TechnicalSignal[]
  patterns         Pattern[]
  newsItems        NewsItem[]
  catalystScores   CatalystScore[]
  riskScores       RiskScore[]
  theses           Thesis[]
  agentOutputs     AgentOutput[]

  @@index([ticker])
  @@index([assetClass])
  @@map("symbols")
}

model SymbolSnapshot {
  id         String   @id @default(cuid())
  symbolId   String
  ticker     String
  open       Float?
  high       Float?
  low        Float?
  close      Float?
  volume     Float?
  marketCap  Float?
  changeAmt  Float?
  changePct  Float?
  vwap       Float?
  snapshotAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  symbol Symbol @relation(fields: [symbolId], references: [id], onDelete: Cascade)

  @@index([symbolId, snapshotAt])
  @@index([ticker])
  @@map("symbol_snapshots")
}

model TechnicalSignal {
  id         String   @id @default(cuid())
  symbolId   String
  ticker     String
  signalType String
  value      Float?
  signal     String?
  timeframe  String   @default("1D")
  metadata   Json?
  capturedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  symbol Symbol @relation(fields: [symbolId], references: [id], onDelete: Cascade)

  @@index([symbolId, signalType])
  @@index([ticker])
  @@map("technical_signals")
}

model Pattern {
  id          String    @id @default(cuid())
  symbolId    String
  ticker      String
  patternType String
  direction   String
  confidence  Float     @default(0)
  startDate   DateTime?
  endDate     DateTime?
  priceTarget Float?
  metadata    Json?
  detectedAt  DateTime  @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  symbol Symbol @relation(fields: [symbolId], references: [id], onDelete: Cascade)

  @@index([symbolId])
  @@index([ticker, patternType])
  @@map("patterns")
}

// ─── News & Catalysts ─────────────────────────────────────────────

model NewsItem {
  id          String    @id @default(cuid())
  symbolId    String?
  ticker      String?
  headline    String
  summary     String?
  url         String?
  source      String?
  sentiment   String?
  impact      String?
  publishedAt DateTime?
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  symbol Symbol? @relation(fields: [symbolId], references: [id], onDelete: SetNull)

  @@index([symbolId])
  @@index([ticker])
  @@index([publishedAt])
  @@map("news_items")
}

model CatalystScore {
  id        String    @id @default(cuid())
  symbolId  String
  ticker    String
  scoreType String
  score     Float     @default(0)
  direction String?
  magnitude String?
  expiresAt DateTime?
  metadata  Json?
  scoredAt  DateTime  @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  symbol Symbol @relation(fields: [symbolId], references: [id], onDelete: Cascade)

  @@index([symbolId])
  @@index([ticker, scoreType])
  @@map("catalyst_scores")
}

model RiskScore {
  id                String   @id @default(cuid())
  symbolId          String
  ticker            String
  overallRisk       Float    @default(0)
  volatilityRisk    Float    @default(0)
  liquidityRisk     Float    @default(0)
  concentrationRisk Float    @default(0)
  marketRisk        Float    @default(0)
  metadata          Json?
  scoredAt          DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  symbol Symbol @relation(fields: [symbolId], references: [id], onDelete: Cascade)

  @@index([symbolId])
  @@index([ticker])
  @@map("risk_scores")
}

// ─── Research ─────────────────────────────────────────────────────

model Thesis {
  id          String      @id @default(cuid())
  userId      String
  symbolId    String?
  ticker      String?
  title       String
  body        String
  conviction  Int         @default(5)
  timeHorizon String?
  tags        String[]
  status      ThesisStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol Symbol? @relation(fields: [symbolId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([ticker])
  @@map("theses")
}

// ─── Paper Trading ────────────────────────────────────────────────

model Portfolio {
  id          String @id @default(cuid())
  userId      String
  name        String
  cashBalance Float  @default(100000)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions PaperPosition[]
  closed    ClosedPosition[]
  metrics   PerformanceMetric[]

  @@index([userId])
  @@map("portfolios")
}

model PaperPosition {
  id           String         @id @default(cuid())
  portfolioId  String
  userId       String
  symbol       String
  name         String
  side         PositionSide
  quantity     Float
  entryPrice   Float
  currentPrice Float?
  targetPrice  Float?
  stopLoss     Float?
  thesis       String
  tags         String[]
  status       PositionStatus @default(OPEN)
  openedAt     DateTime       @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
  @@index([userId])
  @@index([symbol])
  @@map("paper_positions")
}

model ClosedPosition {
  id               String       @id @default(cuid())
  portfolioId      String
  userId           String
  symbol           String
  name             String
  side             PositionSide
  quantity         Float
  entryPrice       Float
  exitPrice        Float
  pnl              Float
  pnlPercent       Float
  thesis           String
  tags             String[]
  notes            String?
  openedAt         DateTime
  closedAt         DateTime     @default(now())
  holdingPeriodDays Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
  @@index([userId])
  @@index([symbol])
  @@map("closed_positions")
}

// ─── Alerts ───────────────────────────────────────────────────────

model Alert {
  id          String         @id @default(cuid())
  userId      String
  symbol      String
  type        AlertType
  condition   AlertCondition
  threshold   Float
  message     String?
  status      AlertStatus    @default(ACTIVE)
  triggeredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([symbol, status])
  @@map("alerts")
}

// ─── Analytics ───────────────────────────────────────────────────

model PerformanceMetric {
  id             String    @id @default(cuid())
  userId         String
  portfolioId    String?
  period         String
  totalTrades    Int       @default(0)
  winningTrades  Int       @default(0)
  losingTrades   Int       @default(0)
  winRate        Float     @default(0)
  avgWin         Float     @default(0)
  avgLoss        Float     @default(0)
  profitFactor   Float     @default(0)
  sharpeRatio    Float?
  maxDrawdown    Float     @default(0)
  totalReturn    Float     @default(0)
  totalReturnPct Float     @default(0)
  metadata       Json?
  periodStart    DateTime?
  periodEnd      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio Portfolio? @relation(fields: [portfolioId], references: [id], onDelete: SetNull)

  @@index([userId, period])
  @@index([portfolioId])
  @@map("performance_metrics")
}

// ─── AI Agent ─────────────────────────────────────────────────────

model AgentOutput {
  id         String  @id @default(cuid())
  userId     String?
  symbolId   String?
  ticker     String?
  agentType  String
  input      Json?
  output     Json?
  score      Float?
  confidence Float?
  metadata   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  symbol Symbol? @relation(fields: [symbolId], references: [id], onDelete: SetNull)

  @@index([userId, agentType])
  @@index([symbolId, agentType])
  @@index([ticker])
  @@map("agent_outputs")
}

model AuditLog {
  id        String  @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ─── Enums ───────────────────────────────────────────────────────

enum AssetClass {
  STOCK
  CRYPTO
  ETF
  FOREX
  FUTURES
}

enum ThesisStatus {
  ACTIVE
  CLOSED
  INVALIDATED
}

enum PositionSide {
  LONG
  SHORT
}

enum PositionStatus {
  OPEN
  CLOSED
  PENDING
}

enum AlertType {
  PRICE
  VOLUME
  NEWS
  TECHNICAL
  CATALYST
}

enum AlertCondition {
  ABOVE
  BELOW
  CROSSES
  PERCENT_CHANGE
}

enum AlertStatus {
  ACTIVE
  TRIGGERED
  DISMISSED
}
